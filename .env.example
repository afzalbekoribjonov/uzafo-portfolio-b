APP_NAME=UZAFO Portfolio API
APP_ENV=production
DEBUG=false
API_PREFIX=/api
MONGO_URI=<YOUR_MONGODB_CONNECTION_STRING>
MONGO_DB=uzafo_portfolio
MONGO_MIN_POOL_SIZE=1
MONGO_MAX_POOL_SIZE=20
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=10000
MONGO_WAIT_QUEUE_TIMEOUT_MS=5000
JWT_SECRET=<GENERATE_A_LONG_RANDOM_SECRET>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=3650
ADMIN_NAME=Afzalbek Oribjonov
ADMIN_EMAIL=orifjonov0916@gmail.com
ADMIN_PASSWORD=<SET_A_STRONG_ADMIN_PASSWORD>
ALLOWED_ORIGINS=https://uzafo.site,https://www.uzafo.site
RATE_LIMIT_STORAGE=memory
SEED_DEMO_DATA=false
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_WEBHOOK_SECRET=
UPLOAD_AUTH_TTL_SECONDS=600
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100
